---
import type { Speaker } from "../../data/speakers";

type Props = {
  speaker: Speaker;
};

const { speaker } = Astro.props;
const imageStyle = speaker.imagePosition
  ? `object-position: ${speaker.imagePosition}`
  : undefined;
---

<a
  href={`/ponentes/${speaker.slug}`}
  class="speaker-card focus-ring group relative isolate block aspect-[4/5] overflow-hidden bg-cip-ink"
  aria-label={`Ver perfil de ${speaker.name}`}
>
  <img
    src={speaker.image}
    alt={`Retrato de ${speaker.name}`}
    width="960"
    height="1200"
    loading="lazy"
    decoding="async"
    style={imageStyle}
    class="h-full w-full object-cover transition duration-300 motion-reduce:transition-none group-hover:scale-[1.035]"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-cip-ink via-cip-ink/25 to-transparent transition duration-300 motion-reduce:transition-none group-hover:from-cip-ink/95" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 p-5 text-white sm:p-6">
    <p class="mb-2 text-xs font-black uppercase tracking-[0.15em] text-cip-maize">{speaker.block}</p>
    <h3 class="text-2xl font-black leading-tight text-white">{speaker.name}</h3>
    <p class="mt-2 text-sm font-bold leading-5 text-cip-cream/90">{speaker.professionalTitle}</p>
    <span class="mt-5 inline-flex items-center gap-2 text-sm font-black text-cip-maize transition duration-300 group-hover:translate-x-1 motion-reduce:transition-none">
      Ver perfil <span aria-hidden="true">→</span>
    </span>
  </div>
</a>
