---
import { event } from "../data/event";
---

<section id="registro" class="relative isolate overflow-hidden bg-cip-navy py-24 text-white">
  <img src="/images/banners/congreso-pattern.webp" alt="" class="absolute inset-0 -z-20 h-full w-full object-cover opacity-10" />
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-cip-navy via-cip-blue to-cip-green/80"></div>

  <div class="section-shell grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
    <div>
      <p class="text-sm font-black uppercase tracking-[0.18em] text-cip-maize">Certificados disponibles</p>
      <h2 class="mt-4 max-w-3xl text-3xl font-black leading-tight sm:text-5xl">
        Solicita tu certificado para el Congreso Zootecnia 2026.
      </h2>
      <p class="mt-6 max-w-2xl text-base leading-8 text-cip-cream/90">
        Completa el formulario oficial, selecciona el tipo de certificado y decide si deseas incluir el almuerzo de confraternidad.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a
          href={event.registrationUrl}
          target="_blank"
          rel="noreferrer"
          class="focus-ring inline-flex justify-center rounded-full bg-cip-copper px-7 py-4 text-sm font-black text-white shadow-gold transition hover:-translate-y-0.5 hover:bg-cip-maize hover:text-cip-ink"
        >
          Solicitar certificado
        </a>
        <a
          href={event.whatsapp.url}
          target="_blank"
          rel="noreferrer"
          class="focus-ring inline-flex justify-center rounded-full border border-white/30 bg-white/10 px-7 py-4 text-sm font-black text-white backdrop-blur transition hover:bg-cip-cream hover:text-cip-navy"
        >
          Consultar por WhatsApp
        </a>
      </div>
      <!-- Para embeber Google Forms mas adelante, pega aqui el iframe oficial y ajusta el alto del contenedor. -->
    </div>

    <div class="rounded-[2rem] border border-white/18 bg-cip-cream/95 p-6 text-cip-ink shadow-lift backdrop-blur">
      <p class="text-xs font-black uppercase tracking-[0.18em] text-cip-gold">Resumen de pago</p>
      <h3 class="mt-3 text-2xl font-black text-cip-navy">Costos disponibles</h3>
      <div class="mt-6 space-y-3">
        {event.prices.map((price) => (
          <div class="flex items-start justify-between gap-4 rounded-2xl border border-cip-border bg-white/70 p-4">
            <div>
              <p class="font-black text-cip-navy">{price.label}</p>
              <p class="mt-1 text-sm text-cip-body">{price.highlight}</p>
            </div>
            <p class="shrink-0 text-lg font-black text-cip-clay">{price.amount}</p>
          </div>
        ))}
      </div>
      <p class="mt-5 rounded-2xl bg-cip-warm p-4 text-sm leading-6 text-cip-body">{event.lunchNote}</p>
    </div>
  </div>
</section>
