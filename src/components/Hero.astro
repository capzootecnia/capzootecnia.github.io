---
import { event } from "../data/event";

const badges = ["Certificado", "Ponencias magistrales", "Almuerzo opcional"];
---

<section id="inicio" class="relative isolate overflow-hidden bg-cip-ink text-white">
  <img
    src="/images/banners/congreso-hero.webp"
    alt=""
    class="absolute inset-0 -z-30 h-full w-full object-cover object-[48%_50%] sm:object-center"
  />
  <div class="absolute inset-0 -z-20 bg-gradient-to-r from-cip-ink/44 via-cip-ink/8 to-transparent"></div>
  <div class="absolute inset-0 -z-20 bg-gradient-to-b from-cip-ink/10 via-transparent to-cip-ink/16"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_19%_20%,rgba(28,24,21,0.35),transparent_25%)]"></div>

  <div class="section-shell grid min-h-[calc(100vh-64px)] items-start gap-6 py-6 sm:py-10 lg:min-h-[calc(100vh-84px)] lg:grid-cols-[0.72fr_0.58fr] lg:pt-16 lg:pb-8">
    <div class="max-w-[520px]">
      <p class="mb-3 inline-flex rounded-full border border-cip-maize/45 bg-cip-ink/30 px-3 py-1.5 text-xs font-black text-cip-maize shadow-soft backdrop-blur sm:px-4 sm:py-2 sm:text-sm">
        {event.dates} · Cusco
      </p>

      <p class="hidden max-w-72 text-[0.68rem] font-black uppercase tracking-[0.16em] text-white/86 drop-shadow-[0_4px_14px_rgba(0,0,0,0.38)] sm:block sm:max-w-none sm:text-sm">
        {event.subtitle}
      </p>
      <h1 class="mt-2 max-w-72 text-[2.08rem] font-black leading-[0.96] tracking-normal text-white drop-shadow-[0_8px_26px_rgba(0,0,0,0.45)] sm:max-w-[520px] sm:text-6xl lg:text-[4.55rem]">
        Congreso Zootecnia 2026
      </h1>
      <p class="mt-3 max-w-72 text-sm leading-6 text-cip-cloud/95 drop-shadow-[0_4px_14px_rgba(0,0,0,0.42)] sm:max-w-[520px] sm:text-lg sm:leading-7">
        {event.motto}
      </p>

      <div class="mt-4 flex flex-wrap gap-2 sm:mt-5 sm:gap-3">
        <a
          href="#registro"
          class="focus-ring inline-flex min-w-32 items-center justify-center rounded-full bg-cip-copper px-5 py-3 text-sm font-black text-white shadow-gold transition hover:-translate-y-0.5 hover:bg-cip-maize hover:text-cip-ink sm:min-w-36 sm:px-6 sm:py-3.5"
        >
          Inscribirme
        </a>
        <a
          href="#cronograma"
          class="focus-ring hidden min-w-36 items-center justify-center rounded-full border border-white/35 bg-white/10 px-6 py-3.5 text-sm font-black text-white backdrop-blur transition hover:bg-cip-cloud hover:text-cip-ink sm:inline-flex"
        >
          Cronograma
        </a>
        <a
          href={event.whatsapp.url}
          target="_blank"
          rel="noreferrer"
          class="focus-ring inline-flex min-w-28 items-center justify-center rounded-full bg-cip-mineral px-5 py-3 text-sm font-black text-white shadow-soft transition hover:-translate-y-0.5 hover:bg-cip-copper sm:min-w-32 sm:px-6 sm:py-3.5"
        >
          WhatsApp
        </a>
      </div>
    </div>

    <div class="hidden w-full max-w-[360px] justify-self-end rounded-[1.4rem] border border-white/16 bg-cip-ink/18 p-3 shadow-lift backdrop-blur-sm lg:block">
      <div class="rounded-2xl border border-cip-maize/30 bg-cip-cloud/88 p-4 text-cip-ink">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-cip-maize">Sede institucional</p>
        <p class="mt-2 text-base font-black">{event.place}</p>
        <p class="mt-1 text-sm leading-6 text-cip-body">{event.address}</p>
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        {badges.map((badge) => (
          <span class="rounded-full border border-white/16 bg-cip-ink/24 px-3 py-2 text-xs font-black uppercase tracking-wide text-cip-maize backdrop-blur-sm">
            {badge}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
